# macOS code signing
# Choose one:
# 1) Reference a certificate already installed in your login keychain
CSC_NAME="Developer ID Application: Your Name (TEAMID1234)"

# 2) Or use a .p12 file in CI / remote machines
# CSC_LINK="/absolute/path/to/DeveloperID.p12"
# CSC_KEY_PASSWORD="your-p12-password"

# Recommended notarization option: App Store Connect API Key
APPLE_API_KEY="/absolute/path/to/AuthKey_ABC1234567.p8"
APPLE_API_KEY_ID="ABC1234567"
APPLE_API_ISSUER="01234567-89ab-cdef-0123-456789abcdef"

# Alternative notarization option: Apple ID + app-specific password
# APPLE_ID="your-apple-id@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="TEAMID1234"

# Alternative notarization option: notarytool keychain profile
# APPLE_KEYCHAIN="$HOME/Library/Keychains/login.keychain-db"
# APPLE_KEYCHAIN_PROFILE="cli-proxy-notary"
